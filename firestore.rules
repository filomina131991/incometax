rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: financialYears
    // Fields: year, schoolName, daPercent, hraPercent, isActive, newRegimeSlabs, standardDeduction, rebateLimit, rebateAmount
    //
    // Collection: teachers
    // Fields: name, penNumber, gender, panNumber, aadhaarNumber, pfNumber, designation, subject, bankAccountNumber, branch, ifscCode, electionId, dob, doj, dor, taxRegime, category, password, basicPay
    //
    // Collection: taxStatements
    // Fields: teacherId, financialYearId, type, monthlyData, festivalAllowance, otherIncome, totalIncome, taxableIncome, taxOnTotalIncome, taxRebate, surcharge, cess, totalTaxPayable, taxDeducted, balanceTax
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "filomina131991@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Rules for financialYears
    match /financialYears/{fyId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Rules for teachers
    match /teachers/{teacherId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Rules for taxStatements
    match /taxStatements/{statementId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || (isAuthenticated() && request.resource.data.teacherId == request.auth.uid);
    }

    // Rules for activities
    match /activities/{activityId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // Rules for users (to store roles)
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isOwner(userId);
    }
  }
}
